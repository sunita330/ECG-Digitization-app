"""
=============================================================================
ECG Image Digitization using Deep Learning
=============================================================================
Author  : Deep Learning Project
Dataset : Custom ECG Images
Input   : ECG image with grid background (Data/sample_ecg.png)
Output  : Clean waveform image, extracted signal coordinates, ECG plot
=============================================================================
"""

# ─────────────────────────────────────────────────────────────────
# SECTION 1 — IMPORTS
# ─────────────────────────────────────────────────────────────────
import os
import cv2
import numpy as np
import matplotlib.pyplot as plt
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader
from torchvision import transforms
from PIL import Image

# ─────────────────────────────────────────────────────────────────
# SECTION 2 — CONFIGURATION
# ─────────────────────────────────────────────────────────────────
INPUT_PATH      = "Data/sample_ecg.png"
OUTPUT_DIR      = "Output"
GRID_KERNEL_H   = 40   # horizontal kernel width for grid removal
GRID_KERNEL_V   = 40   # vertical kernel height for grid removal
DILATE_ITER     = 2    # dilation iterations for waveform enhancement
CLOSE_KERNEL    = 5    # closing kernel size
IMG_SIZE        = 512  # U-Net input size
NUM_EPOCHS      = 50
BATCH_SIZE      = 4
LEARNING_RATE   = 1e-4
NUM_CLASSES     = 1    # binary segmentation

os.makedirs(OUTPUT_DIR, exist_ok=True)


# =============================================================================
# PART 1 — CLASSICAL PREPROCESSING PIPELINE
# =============================================================================

def load_and_grayscale(image_path: str) -> tuple:
    """
    Load image from disk and convert to grayscale.

    Args:
        image_path: Path to the ECG image file.

    Returns:
        Tuple of (original BGR image, grayscale image).
    """
    img_bgr  = cv2.imread(image_path)
    if img_bgr is None:
        raise FileNotFoundError(f"Image not found at: {image_path}")
    img_gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)
    print(f"[1] Image loaded  — shape: {img_bgr.shape}")
    return img_bgr, img_gray


def apply_threshold(gray: np.ndarray) -> np.ndarray:
    """
    Apply Otsu's binary thresholding to separate waveform from background.

    Args:
        gray: Grayscale ECG image.

    Returns:
        Binary (thresholded) image.
    """
    _, binary = cv2.threshold(
        gray, 0, 255,
        cv2.THRESH_BINARY_INV + cv2.THRESH_OTSU
    )
    print(f"[2] Thresholding applied (Otsu)")
    return binary


def remove_grid(binary: np.ndarray,
                h_len: int = GRID_KERNEL_H,
                v_len: int = GRID_KERNEL_V) -> np.ndarray:
    """
    Remove horizontal and vertical grid lines using morphological operations.

    Strategy:
        1. Detect horizontal lines with a wide flat kernel.
        2. Detect vertical lines with a tall thin kernel.
        3. Combine detected grid into a single mask.
        4. Subtract grid mask from the binary image.

    Args:
        binary : Binary (thresholded) image.
        h_len  : Length of horizontal structuring element.
        v_len  : Length of vertical structuring element.

    Returns:
        Binary image with grid lines removed.
    """
    # --- Horizontal grid lines ---
    h_kernel     = cv2.getStructuringElement(cv2.MORPH_RECT, (h_len, 1))
    h_lines      = cv2.morphologyEx(binary, cv2.MORPH_OPEN, h_kernel)

    # --- Vertical grid lines ---
    v_kernel     = cv2.getStructuringElement(cv2.MORPH_RECT, (1, v_len))
    v_lines      = cv2.morphologyEx(binary, cv2.MORPH_OPEN, v_kernel)

    # --- Combine grid mask ---
    grid_mask    = cv2.add(h_lines, v_lines)

    # --- Subtract grid from binary image ---
    no_grid      = cv2.subtract(binary, grid_mask)
    print(f"[3] Grid removed — horizontal kernel ({h_len}x1), vertical kernel (1x{v_len})")
    return no_grid


def enhance_waveform(no_grid: np.ndarray,
                     dilate_iter: int = DILATE_ITER,
                     close_k: int    = CLOSE_KERNEL) -> np.ndarray:
    """
    Enhance the ECG waveform using dilation and morphological closing.

    Args:
        no_grid    : Image after grid removal.
        dilate_iter: Number of dilation iterations.
        close_k    : Kernel size for closing operation.

    Returns:
        Enhanced waveform image.
    """
    # Dilation — thickens the thin waveform lines
    d_kernel  = cv2.getStructuringElement(cv2.MORPH_RECT, (2, 2))
    dilated   = cv2.dilate(no_grid, d_kernel, iterations=dilate_iter)

    # Closing — fills small gaps in the waveform
    c_kernel  = cv2.getStructuringElement(cv2.MORPH_RECT, (close_k, close_k))
    enhanced  = cv2.morphologyEx(dilated, cv2.MORPH_CLOSE, c_kernel)
    print(f"[4] Waveform enhanced — dilation x{dilate_iter}, closing k={close_k}")
    return enhanced


def extract_signal(enhanced: np.ndarray) -> tuple:
    """
    Extract (x, y) signal coordinates from the enhanced waveform image.

    For each column x, the waveform y-coordinate is taken as the vertical
    centroid of all active (white) pixels in that column.

    Args:
        enhanced: Enhanced binary waveform image.

    Returns:
        Tuple of (x_coords array, y_coords array).
    """
    h, w        = enhanced.shape
    x_coords    = []
    y_coords    = []

    for x in range(w):
        col          = enhanced[:, x]
        active_rows  = np.where(col > 0)[0]
        if len(active_rows) > 0:
            y_mean = int(np.mean(active_rows))
            x_coords.append(x)
            y_coords.append(h - y_mean)  # flip so signal goes upward

    x_arr = np.array(x_coords)
    y_arr = np.array(y_coords)
    print(f"[5] Signal extracted — {len(x_arr)} data points")
    return x_arr, y_arr


def plot_signal(x: np.ndarray, y: np.ndarray, output_path: str) -> None:
    """
    Plot the extracted ECG signal and save to disk.

    Args:
        x          : Array of x-coordinates (pixel columns).
        y          : Array of y-coordinates (signal amplitude).
        output_path: File path to save the plot.
    """
    plt.figure(figsize=(14, 4))
    plt.plot(x, y, color='red', linewidth=1.2, label='ECG Signal')
    plt.title("Extracted ECG Signal", fontsize=14)
    plt.xlabel("Time (pixels)", fontsize=11)
    plt.ylabel("Amplitude (pixels)", fontsize=11)
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.5)
    plt.tight_layout()
    plt.savefig(output_path, dpi=150)
    plt.close()
    print(f"[6] Signal plot saved → {output_path}")


def save_stage_images(stages: dict, out_dir: str) -> None:
    """
    Save intermediate processing stage images to disk.

    Args:
        stages : Dict mapping filename suffix to image array.
        out_dir: Directory to save images.
    """
    for name, img in stages.items():
        path = os.path.join(out_dir, name)
        cv2.imwrite(path, img)
    print(f"[*] Stage images saved to: {out_dir}")


def run_classical_pipeline(image_path: str = INPUT_PATH) -> tuple:
    """
    Execute the full classical ECG digitization pipeline.

    Steps:
        1. Load & grayscale
        2. Binary thresholding (Otsu)
        3. Grid removal (horizontal + vertical morphology)
        4. Waveform enhancement (dilation + closing)
        5. Signal extraction (centroid per column)
        6. Plot & save

    Args:
        image_path: Path to input ECG image.

    Returns:
        Tuple of (x_coords, y_coords, enhanced_image).
    """
    print("=" * 60)
    print("  ECG DIGITIZATION — CLASSICAL PIPELINE")
    print("=" * 60)

    img_bgr,  img_gray = load_and_grayscale(image_path)
    binary             = apply_threshold(img_gray)
    no_grid            = remove_grid(binary)
    enhanced           = enhance_waveform(no_grid)
    x, y               = extract_signal(enhanced)

    # Save outputs
    plot_signal(x, y, os.path.join(OUTPUT_DIR, "ecg_signal_plot.png"))
    save_stage_images({
        "01_grayscale.png" : img_gray,
        "02_binary.png"    : binary,
        "03_no_grid.png"   : no_grid,
        "04_enhanced.png"  : enhanced,
    }, OUTPUT_DIR)

    print("=" * 60)
    print("  PIPELINE COMPLETE")
    print("=" * 60)
    return x, y, enhanced


# =============================================================================
# PART 2 — U-NET DEEP LEARNING MODEL (PyTorch)
# =============================================================================

class ConvBlock(nn.Module):
    """
    Double Convolution Block: Conv → BN → ReLU → Conv → BN → ReLU.
    Used in both encoder and decoder paths of U-Net.
    """
    def __init__(self, in_ch: int, out_ch: int):
        super().__init__()
        self.block = nn.Sequential(
            nn.Conv2d(in_ch,  out_ch, kernel_size=3, padding=1, bias=False),
            nn.BatchNorm2d(out_ch),
            nn.ReLU(inplace=True),
            nn.Conv2d(out_ch, out_ch, kernel_size=3, padding=1, bias=False),
            nn.BatchNorm2d(out_ch),
            nn.ReLU(inplace=True),
        )

    def forward(self, x):
        return self.block(x)


class EncoderBlock(nn.Module):
    """
    Encoder block: ConvBlock followed by MaxPool2d(2×2).
    Returns both the skip-connection feature map and the pooled output.
    """
    def __init__(self, in_ch: int, out_ch: int):
        super().__init__()
        self.conv = ConvBlock(in_ch, out_ch)
        self.pool = nn.MaxPool2d(2)

    def forward(self, x):
        skip    = self.conv(x)
        pooled  = self.pool(skip)
        return skip, pooled


class DecoderBlock(nn.Module):
    """
    Decoder block: Upsample → concatenate skip → ConvBlock.
    """
    def __init__(self, in_ch: int, out_ch: int):
        super().__init__()
        self.up   = nn.ConvTranspose2d(in_ch, out_ch, kernel_size=2, stride=2)
        self.conv = ConvBlock(in_ch, out_ch)

    def forward(self, x, skip):
        x = self.up(x)
        x = torch.cat([x, skip], dim=1)  # channel-wise concat
        return self.conv(x)


class UNet(nn.Module):
    """
    U-Net architecture for binary ECG waveform segmentation.

    Architecture (encoder channels): 1 → 64 → 128 → 256 → 512 → 1024 (bottleneck)
    Decoder mirrors encoder with skip connections at each level.

    Input  : (B, 1, H, W)  — single-channel (grayscale) ECG image
    Output : (B, 1, H, W)  — segmentation probability map (0=background, 1=waveform)
    """
    def __init__(self, in_ch: int = 1, out_ch: int = 1):
        super().__init__()

        # ── Encoder ──────────────────────────────────────────────
        self.enc1 = EncoderBlock(in_ch,  64)
        self.enc2 = EncoderBlock(64,    128)
        self.enc3 = EncoderBlock(128,   256)
        self.enc4 = EncoderBlock(256,   512)

        # ── Bottleneck ───────────────────────────────────────────
        self.bottleneck = ConvBlock(512, 1024)

        # ── Decoder ──────────────────────────────────────────────
        self.dec4 = DecoderBlock(1024, 512)
        self.dec3 = DecoderBlock(512,  256)
        self.dec2 = DecoderBlock(256,  128)
        self.dec1 = DecoderBlock(128,   64)

        # ── Output Head ──────────────────────────────────────────
        self.out_conv = nn.Conv2d(64, out_ch, kernel_size=1)

    def forward(self, x):
        # Encoder path (with skip connections)
        s1, p1 = self.enc1(x)
        s2, p2 = self.enc2(p1)
        s3, p3 = self.enc3(p2)
        s4, p4 = self.enc4(p3)

        # Bottleneck
        b = self.bottleneck(p4)

        # Decoder path (concatenate skip connections)
        d4 = self.dec4(b,  s4)
        d3 = self.dec3(d4, s3)
        d2 = self.dec2(d3, s2)
        d1 = self.dec1(d2, s1)

        # Final output — sigmoid gives probability map
        return torch.sigmoid(self.out_conv(d1))


# ─────────────────────────────────────────────────────────────────
# DATASET CLASS
# ─────────────────────────────────────────────────────────────────
class ECGDataset(Dataset):
    """
    Custom Dataset for ECG segmentation.
    Expects paired image + mask directories.

    Directory structure:
        data/
            images/  ← raw ECG images  (PNG)
            masks/   ← binary masks    (PNG, 0 or 255)
    """
    def __init__(self, img_dir: str, mask_dir: str, img_size: int = IMG_SIZE):
        self.img_paths  = sorted([
            os.path.join(img_dir, f) for f in os.listdir(img_dir)
            if f.endswith(('.png', '.jpg'))
        ])
        self.mask_paths = sorted([
            os.path.join(mask_dir, f) for f in os.listdir(mask_dir)
            if f.endswith(('.png', '.jpg'))
        ])
        self.transform  = transforms.Compose([
            transforms.Resize((img_size, img_size)),
            transforms.ToTensor(),
        ])

    def __len__(self):
        return len(self.img_paths)

    def __getitem__(self, idx):
        image = Image.open(self.img_paths[idx]).convert("L")
        mask  = Image.open(self.mask_paths[idx]).convert("L")
        return self.transform(image), self.transform(mask)


# ─────────────────────────────────────────────────────────────────
# LOSS FUNCTION — Binary Cross-Entropy + Dice Loss
# ─────────────────────────────────────────────────────────────────
class BCEDiceLoss(nn.Module):
    """
    Combined Binary Cross-Entropy and Dice Loss for segmentation.
    Dice Loss handles class imbalance (thin waveform vs large background).
    """
    def __init__(self, smooth: float = 1e-6):
        super().__init__()
        self.bce    = nn.BCELoss()
        self.smooth = smooth

    def dice_loss(self, pred, target):
        intersection = (pred * target).sum()
        return 1 - (2 * intersection + self.smooth) / \
               (pred.sum() + target.sum() + self.smooth)

    def forward(self, pred, target):
        bce  = self.bce(pred, target)
        dice = self.dice_loss(pred, target)
        return bce + dice


# ─────────────────────────────────────────────────────────────────
# TRAINING LOOP
# ─────────────────────────────────────────────────────────────────
def train_unet(model, train_loader, val_loader,
               num_epochs: int = NUM_EPOCHS,
               lr: float       = LEARNING_RATE,
               device: str     = "cuda" if torch.cuda.is_available() else "cpu"):
    """
    Train the U-Net model with BCE+Dice loss and Adam optimizer.

    Args:
        model       : UNet instance.
        train_loader: Training DataLoader.
        val_loader  : Validation DataLoader.
        num_epochs  : Number of training epochs.
        lr          : Learning rate for Adam optimizer.
        device      : 'cuda' or 'cpu'.

    Returns:
        Dict containing train_loss and val_loss history lists.
    """
    model     = model.to(device)
    criterion = BCEDiceLoss()
    optimizer = optim.Adam(model.parameters(), lr=lr)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, patience=5, factor=0.5)

    history = {"train_loss": [], "val_loss": []}

    for epoch in range(1, num_epochs + 1):
        # ── Training ─────────────────────────────────────────────
        model.train()
        train_loss = 0.0
        for imgs, masks in train_loader:
            imgs, masks = imgs.to(device), masks.to(device)
            optimizer.zero_grad()
            preds      = model(imgs)
            loss       = criterion(preds, masks)
            loss.backward()
            optimizer.step()
            train_loss += loss.item()

        # ── Validation ───────────────────────────────────────────
        model.eval()
        val_loss = 0.0
        with torch.no_grad():
            for imgs, masks in val_loader:
                imgs, masks = imgs.to(device), masks.to(device)
                preds    = model(imgs)
                val_loss += criterion(preds, masks).item()

        train_loss /= len(train_loader)
        val_loss   /= len(val_loader)
        scheduler.step(val_loss)

        history["train_loss"].append(train_loss)
        history["val_loss"].append(val_loss)

        if epoch % 10 == 0 or epoch == 1:
            print(f"Epoch [{epoch:3d}/{num_epochs}]  "
                  f"Train Loss: {train_loss:.4f}  |  Val Loss: {val_loss:.4f}")

    return history


def plot_loss_curve(history: dict, output_path: str) -> None:
    """
    Plot and save the training/validation loss curve.

    Args:
        history    : Dict with 'train_loss' and 'val_loss' lists.
        output_path: File path to save the plot.
    """
    plt.figure(figsize=(9, 4))
    plt.plot(history["train_loss"], label="Train Loss",      color='blue',   linewidth=2)
    plt.plot(history["val_loss"],   label="Validation Loss", color='orange',  linewidth=2)
    plt.title("U-Net Training Loss Curve", fontsize=14)
    plt.xlabel("Epoch")
    plt.ylabel("BCE + Dice Loss")
    plt.legend()
    plt.grid(True, linestyle='--', alpha=0.5)
    plt.tight_layout()
    plt.savefig(output_path, dpi=150)
    plt.close()
    print(f"[*] Loss curve saved → {output_path}")


def predict_mask(model, image_path: str,
                 device: str = "cuda" if torch.cuda.is_available() else "cpu") -> np.ndarray:
    """
    Run inference on a single ECG image and return the predicted mask.

    Args:
        model     : Trained UNet instance.
        image_path: Path to ECG image.
        device    : Inference device.

    Returns:
        Binary mask as numpy array (0/255).
    """
    transform = transforms.Compose([
        transforms.Resize((IMG_SIZE, IMG_SIZE)),
        transforms.ToTensor(),
    ])
    image  = Image.open(image_path).convert("L")
    tensor = transform(image).unsqueeze(0).to(device)

    model.eval()
    with torch.no_grad():
        pred = model(tensor).squeeze().cpu().numpy()

    mask = (pred > 0.5).astype(np.uint8) * 255
    return mask


